# Public site URL (used for canonical, OGP, sitemap)
NEXT_PUBLIC_SITE_URL=https://your-public-domain.example

# Supabase (read-only public access via anon key — same project as the admin app)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Do NOT put SUPABASE_SERVICE_ROLE_KEY or RESEND_API_KEY here.
# The public site is read-only and must never use server secrets.
