# Public site URL (used for canonical, OGP, sitemap)
NEXT_PUBLIC_SITE_URL=https://your-public-domain.example

# Supabase (read-only public access via anon key — same project as the admin app)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Do NOT put SUPABASE_SERVICE_ROLE_KEY or RESEND_API_KEY here.
# The public site is read-only and must never use server secrets.

# Google Maps Embed API (client-side embed only — restrict by HTTP referrer in GCP)
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=your-maps-embed-api-key

# Google Places API (New) — server-side only (used by /api/google-places/* and shop detail pages)
GOOGLE_PLACES_API_KEY=your-places-api-key

# Local preview only: show opening hours on a shop without saving place_id to DB
# GOOGLE_PLACES_PREVIEW_SHOP_SLUG=cafe-107
# GOOGLE_PLACES_PREVIEW_PLACE_ID=ChIJxxxxxxxx
